# Scout — copy to .env and adjust as needed.
# Optional: database URL (defaults to SQLite below if not set)
# DATABASE_URL=sqlite:///./data/scout.db

# Optional: path for SQLite DB (used only if DATABASE_URL is not set). Relative to cwd when running the app.
# SQLITE_PATH=./data/scout.db

# Phase 2: AI match scoring (required for GET /api/scores/{listing_id})
# Get key at https://console.groq.com
# GROQ_API_KEY=your_groq_api_key_here
# Optional: Groq model (default llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Phase 4: Cover letter generation (required for POST /api/cover-letter/generate)
# Get key at https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your_gemini_api_key_here
# Optional: override model (e.g. gemini-2.5-flash-lite, gemini-1.5-flash-latest)
# GEMINI_COVER_MODEL=gemini-2.5-flash

# Optional: Indeed RSS feeds. Comma-separated "query|location" (e.g. software+engineer+remote|,internship|)
# INDEED_RSS_QUERIES=software engineer remote|,internship remote|,developer|
